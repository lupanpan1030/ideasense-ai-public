# API routing
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Captcha UI. Keep these aligned with backend CAPTCHA_REQUIRED/CAPTCHA_PROVIDER.
# When backend captcha is required, NEXT_PUBLIC_CAPTCHA_SITE_KEY must be set
# or register, password reset, and verification resend requests will fail.
# NEXT_PUBLIC_CAPTCHA_PROVIDER=hcaptcha
# NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# When NEXT_PUBLIC_API_BASE_URL is empty, rewrites use BACKEND_INTERNAL_URL
# BACKEND_INTERNAL_URL=http://localhost:8000
