# Database (required)
DATABASE_URL=postgresql+psycopg2://ideasense_user:ideasense_pwd@localhost:5432/ideasense_ai_dev
DATABASE_URL_ADMIN=postgresql+psycopg2://ideasense_user:ideasense_pwd@localhost:5432/ideasense_ai_dev

# Auth (choose one path)
# Option A: Dev auth bypass (no login required)
DEV_AUTH_BYPASS=1
DEV_USER_ID=99999999-9999-9999-9999-999999999999
DEV_ORG_ID=11111111-1111-1111-1111-111111111111
DEV_ACTOR_TYPE=user

# Option B: JWT login
# DEV_LOGIN_ENABLED=1
# JWT_SECRET=dev-secret-change-me
# JWT_EXPIRES_MINUTES=60
# JWT_REFRESH_THRESHOLD_MINUTES=10
# JWT_ALGORITHM=HS256

# App / API
APP_ENV=development
ADMIN_API_ENABLED=1
ADMIN_ENABLED=1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Public sample API. If unset, defaults to enabled outside production and disabled in production.
# SAMPLE_PUBLIC_ENABLED=1

# Captcha enforcement. Keep provider aligned with frontend NEXT_PUBLIC_CAPTCHA_PROVIDER.
# CAPTCHA_REQUIRED defaults to 1 in production; set the matching frontend site key.
# CAPTCHA_REQUIRED=0
# CAPTCHA_PROVIDER=hcaptcha
# CAPTCHA_SECRET_KEY=
# CAPTCHA_VERIFY_URL=
# CAPTCHA_MIN_SCORE=0.5

# Email verification (optional)
# RESEND_API_KEY=
# EMAIL_FROM="IdeaSense AI <no-reply@mg.ideasenseai.com>"
# EMAIL_REPLY_TO="ideasenseai@gmail.com"
# EMAIL_VERIFY_BASE_URL=http://localhost:3000

# LLM providers (optional; see backend/README.md for full list)
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_PRO_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# QWEN_API_KEY=
# QWEN_MODEL=qwen3.5-plus
# QWEN_PRO_MODEL=qwen3-max
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# For China (Beijing) keys, use:
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_PRO_MODEL=gemini-3.5-flash
LLM_PROVIDER_DEFAULT=deepseek,qwen,gemini,bedrock,openai
LLM_PROVIDER_AI_ASSIST=deepseek,qwen,gemini,openai
LLM_PROVIDER_EXTRACT=deepseek,qwen,gemini,openai
LLM_PROVIDER_FOLLOWUP_COMPOSE=qwen,gemini,deepseek,openai
LLM_PROVIDER_QUESTION_COMPOSE=qwen,gemini,deepseek,openai
LLM_PROVIDER_QUESTION_REWRITE=qwen,deepseek,gemini,openai
LLM_PROVIDER_ROUTER=deepseek,qwen,gemini,openai
LLM_PROVIDER_QA_DIGEST=deepseek,qwen,gemini,openai
LLM_PROVIDER_ANSWER_GATE=deepseek,qwen,gemini,openai
LLM_PROVIDER_STAGE_SUMMARY=deepseek,qwen,gemini,openai
LLM_PROVIDER_DVF_SCORING=deepseek,qwen,gemini,openai
LLM_PROVIDER_REPORT=qwen,deepseek,gemini,openai
# Visible answer-gate timeout. Extraction and summaries run through workers.
ANSWER_GATE_TIMEOUT_MS=3000
# Background extract prompt timeout; does not block chat response streaming.
SYNC_EXTRACT_TIMEOUT_MS=2500
QUESTION_COMPOSE_START_TIMEOUT_MS=3500
QUESTION_PLANNER_TIMEOUT_MS=1000
QUESTION_PLANNER_MIN_MISSING_PATHS=2
QUESTION_PLANNER_MIN_CANDIDATES=2

# Evidence verification (optional)
# IDEASENSE_VERIFICATION_ENABLED=1
# IDEASENSE_TAVILY_SEARCH_ENABLED=1
# TAVILY_API_KEY=
# IDEASENSE_VERIFICATION_MIN_PRIORITY=medium
# IDEASENSE_VERIFICATION_MAX_CLAIMS=8
# IDEASENSE_VERIFICATION_MAX_RESULTS=3
# IDEASENSE_VERIFICATION_TIMEOUT_S=8

# Invites / links (optional)
# APP_BASE_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
